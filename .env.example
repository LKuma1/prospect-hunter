# Prospect Hunter — Variáveis de Ambiente

# URL base da aplicação (necessário para Server Components fazerem fetch interno)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Token da API Apify (obrigatório)
# Obtenha em: https://console.apify.com/account/integrations
APIFY_TOKEN=

# Chave da API Google Gemini (obrigatório)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# URL de conexão PostgreSQL — Supabase
# Encontre em: Supabase Dashboard → Settings → Database → Connection string → URI
# Use a "Transaction pooler" URL (porta 6543) para Vercel serverless
DATABASE_URL=postgresql://postgres:[senha]@db.[ref].supabase.co:6543/postgres?pgbouncer=true
