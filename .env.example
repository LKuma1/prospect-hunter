# Prospect Hunter — Variáveis de Ambiente

# URL base da aplicação (necessário para Server Components fazerem fetch interno)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Token da API Apify (obrigatório)
# Obtenha em: https://console.apify.com/account/integrations
APIFY_TOKEN=

# Chave da API Google Gemini (obrigatório)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Caminho do banco SQLite (opcional — padrão: ./prospect-hunter.db)
# DATABASE_URL=./prospect-hunter.db
